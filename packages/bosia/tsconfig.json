{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"lib": ["dom", "dom.iterable", "esnext"],
		"types": ["bun"],
		"rootDirs": [".", ".bosia/types"]
	},
	"include": ["src/**/*", "src/**/*.d.ts"]
}
