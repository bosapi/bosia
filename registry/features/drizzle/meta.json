{
	"name": "drizzle",
	"description": "Adds Drizzle ORM (postgres / mysql / sqlite via Bun built-in driver) — DB connection, schema aggregator, migration dir, and seed runner.",
	"components": [],
	"options": [
		{
			"name": "dialect",
			"flag": "-d",
			"long": "--dialect",
			"prompt": "Which database dialect should drizzle use?",
			"choices": [
				{ "value": "sqlite", "label": "SQLite", "hint": "default — zero-config" },
				{ "value": "postgres", "label": "Postgres" },
				{ "value": "mysql", "label": "MySQL" }
			],
			"default": "sqlite"
		}
	],
	"files": [
		{
			"src": "drizzle-index.pg.ts",
			"target": "src/features/drizzle/index.ts",
			"strategy": "skip-if-exists",
			"when": { "dialect": "postgres" }
		},
		{
			"src": "drizzle-index.mysql.ts",
			"target": "src/features/drizzle/index.ts",
			"strategy": "skip-if-exists",
			"when": { "dialect": "mysql" }
		},
		{
			"src": "drizzle-index.sqlite.ts",
			"target": "src/features/drizzle/index.ts",
			"strategy": "skip-if-exists",
			"when": { "dialect": "sqlite" }
		},
		{
			"src": "drizzle-schemas.ts",
			"target": "src/features/drizzle/schemas.ts",
			"strategy": "skip-if-exists"
		},
		{
			"src": "migrations-gitkeep",
			"target": "src/features/drizzle/migrations/.gitkeep",
			"strategy": "skip-if-exists"
		},
		{
			"src": "seed-runner.pg.ts",
			"target": "src/features/drizzle/seeds/runner.ts",
			"strategy": "skip-if-exists",
			"when": { "dialect": "postgres" }
		},
		{
			"src": "seed-runner.mysql.ts",
			"target": "src/features/drizzle/seeds/runner.ts",
			"strategy": "skip-if-exists",
			"when": { "dialect": "mysql" }
		},
		{
			"src": "seed-runner.sqlite.ts",
			"target": "src/features/drizzle/seeds/runner.ts",
			"strategy": "skip-if-exists",
			"when": { "dialect": "sqlite" }
		},
		{
			"src": "drizzle-migrate.pg.ts",
			"target": "src/features/drizzle/migrate.ts",
			"strategy": "skip-if-exists",
			"when": { "dialect": "postgres" }
		},
		{
			"src": "drizzle-migrate.mysql.ts",
			"target": "src/features/drizzle/migrate.ts",
			"strategy": "skip-if-exists",
			"when": { "dialect": "mysql" }
		},
		{
			"src": "drizzle-migrate.sqlite.ts",
			"target": "src/features/drizzle/migrate.ts",
			"strategy": "skip-if-exists",
			"when": { "dialect": "sqlite" }
		},
		{
			"src": "drizzle.config.ts",
			"target": "drizzle.config.ts",
			"strategy": "skip-if-exists"
		}
	],
	"npmDeps": {
		"drizzle-orm": "^0.44.0"
	},
	"npmDevDeps": {
		"drizzle-kit": "^0.31.0"
	},
	"scripts": {
		"db:generate": "drizzle-kit generate",
		"db:migrate": "bun run src/features/drizzle/migrate.ts",
		"db:seed": "bun run src/features/drizzle/seeds/runner.ts"
	},
	"envVars": {
		"DATABASE_URL": "sqlite://./data/app.db"
	}
}
