{
	"extends": "../packages/bosia/tsconfig.json",
	"compilerOptions": {
		"paths": {
			"$lib/utils.ts": ["../packages/bosia/src/lib/utils.ts"],
			"$lib/utils": ["../packages/bosia/src/lib/utils.ts"],
